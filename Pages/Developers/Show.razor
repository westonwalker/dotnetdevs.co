										}
									</div>
									<div class="block xl:hidden w-full pb-12 px-6">
										<p class="leading-loose lg:leading-loose text-sm sm:text-base text-gray-900">
											@((MarkupString)(developer.Bio))
										</p>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
}

@code {
	[Parameter]
	public int ID { get; set; }
	[CascadingParameter]
	public MainLayout Layout { get; set; }
	private Developer? developer;
	private Company? company => Layout.Company;
	private ApplicationUser? user => Layout.User;
	private bool isSubscribed = false;

	protected override async Task OnInitializedAsync()
	{
		ID = ID;
		developer = await developerService.Get(ID);
		// TODO: retreive company and check if subscribed
		if (developer == null)
		{
			NavManager.NavigateTo($"/developers");
		}
		if ((user != null && company != null && company.IsSubscribed) || (user != null && developer.UserID == user.Id))
		{
			isSubscribed = true;
		}
	}
}
