@page "/developers/{id:int}"
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Identity
@using System.Web
@using System.Text.RegularExpressions;
@inject DeveloperService developerService
@inject CompanyService companyService
@inject UserService userService
@inject NavigationManager NavManager

@if (developer == null)
{
}
else
{
	<PageTitle>@developer.Hero</PageTitle>

	<div class="">
		<div class="relative flex flex-wrap justify-center items-center py-12 md:py-20 max-w-6xl mx-auto sm:px-8">
			<div class="flex-1">
				<div class="bg-white border-y sm:border border-gray-600 shadow-2xl">
					<div class="relative">
						<div class="flex sm:space-x-8 flex-col sm:flex-row">
							<div class="shrink-0 pt-6 px-6 sm:p-6">
								<img alt="@developer.Hero avatar" class="h-20 w-20 sm:h-32 sm:w-32 object-cover bg-transparent border border-gray-100" src="@developer.Avatar">
							</div>
							<div class="self-start flex-1 min-w-0 space-y-3 mt-4 sm:mt-0">
								<div class="flex flex-col xl:flex-row gap-x-6 space-y-4 xl:space-y-0">
									<div class="w-full xl:w-2/3 pb-6 px-6 sm:p-6">
										<div class="flex items-start justify-between space-x-2">
											<h1 class="text-xl sm:text-2xl font-medium text-black" title="Junior Fullstack Developer React + Rails.">
												@developer.Hero
											</h1>
											<div class="inline-flex ml-auto flex-row-reverse shrink-0 items-center text-gray-400">
												<div class="flex items-center">
													@if (user != null && developer.UserID == user.Id)
													{
														<a href="/developers/edit/@developer.ID" class="text-base font-semibold text-white bg-indigo-600 hover:bg-indigo-700 leading-loose relative flex items-center justify-center py-1 px-4 mx-auto w-auto max-w-sm md:w-auto">
															Edit
														</a>
													}
													else
													{
														@if (isSubscribed)
														{
															<a href="/conversations/@developer.ID/create/" class="text-base font-semibold text-white bg-indigo-600 hover:bg-indigo-700 leading-loose relative flex items-center justify-center py-1 px-4 mx-auto w-auto max-w-sm md:w-auto">
																Hire
															</a>
														}
														else
														{
															<a href="/pricing" class="text-base font-semibold text-white bg-indigo-600 hover:bg-indigo-700 leading-loose relative flex items-center justify-center py-1 px-4 mx-auto w-auto max-w-sm md:w-auto">
																Hire
															</a>
														}
													}
												</div>
											</div>
										</div>
										@if (isSubscribed)
										{
											<div>
												<p class="text-gray-500 font-medium inline-flex items-center">
													<svg class="w-4 h-4 fill-gray-500 mr-2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
														<path fill-rule="evenodd" d="M7.5 6a4.5 4.5 0 119 0 4.5 4.5 0 01-9 0zM3.751 20.105a8.25 8.25 0 0116.498 0 .75.75 0 01-.437.695A18.683 18.683 0 0112 22.5c-2.786 0-5.433-.608-7.812-1.7a.75.75 0 01-.437-.695z" clip-rule="evenodd" />
													</svg>
													<span>@developer.FullName</span>
												</p>
											</div>
										}
										<div class="flex flex-row space-x-4 items-start mt-2">
											<span class="inline-flex items-center rounded-md px-2.5 py-0.5 text-xs sm:text-sm font-medium bg-green-100 text-green-800 border border-green-800">Recently Active</span>
										</div>
										<div class="hidden xl:block w-full mt-12">
											<p class="leading-loose lg:leading-loose text-sm sm:text-base text-gray-700">
												@((MarkupString)(developer.Bio))
											</p>
										</div>
									</div>
									<div class="space-y-5 w-full xl:w-1/3 pb-6 px-6 xl:p-6">
										@if (isSubscribed)
										{
											<div class="flex flex-wrap flex-row xl:flex-col items-start space-y-3">
												<div class="w-full sm:w-1/2 xl:w-full mt-3 xl:mt-0">
													<h5 class="text-sm font-medium text-gray-400 mb-1">Search status</h5>
													<p class="text-gray-900 inline-flex items-center">
														<svg class="w-4 h-4 fill-gray-400 mr-2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
															<path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12zM12 8.25a.75.75 0 01.75.75v3.75a.75.75 0 01-1.5 0V9a.75.75 0 01.75-.75zm0 8.25a.75.75 0 100-1.5.75.75 0 000 1.5z" clip-rule="evenodd" />
														</svg>
														<span>@developer.SearchStatus.Name</span>
													</p>
												</div>
												<div class="w-full sm:w-1/2 xl:w-full">
													<h5 class="text-sm font-medium text-gray-400 mb-1">Start date</h5>
													<p class="text-gray-900 inline-flex items-center">
														<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 fill-gray-400 mr-2">
															<path d="M12.75 12.75a.75.75 0 11-1.5 0 .75.75 0 011.5 0zM7.5 15.75a.75.75 0 100-1.5.75.75 0 000 1.5zM8.25 17.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zM9.75 15.75a.75.75 0 100-1.5.75.75 0 000 1.5zM10.5 17.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zM12 15.75a.75.75 0 100-1.5.75.75 0 000 1.5zM12.75 17.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zM14.25 15.75a.75.75 0 100-1.5.75.75 0 000 1.5zM15 17.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zM16.5 15.75a.75.75 0 100-1.5.75.75 0 000 1.5zM15 12.75a.75.75 0 11-1.5 0 .75.75 0 011.5 0zM16.5 13.5a.75.75 0 100-1.5.75.75 0 000 1.5z" />
															<path fill-rule="evenodd" d="M6.75 2.25A.75.75 0 017.5 3v1.5h9V3A.75.75 0 0118 3v1.5h.75a3 3 0 013 3v11.25a3 3 0 01-3 3H5.25a3 3 0 01-3-3V7.5a3 3 0 013-3H6V3a.75.75 0 01.75-.75zm13.5 9a1.5 1.5 0 00-1.5-1.5H5.25a1.5 1.5 0 00-1.5 1.5v7.5a1.5 1.5 0 001.5 1.5h13.5a1.5 1.5 0 001.5-1.5v-7.5z" clip-rule="evenodd" />
														</svg>
														<span>@developer.StartDate.ToShortDateString()</span>
													</p>
												</div>
												<div class="w-full sm:w-1/2 xl:w-full">
													<h5 class="text-sm font-medium text-gray-400 mb-1">Experience level</h5>
