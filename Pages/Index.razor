@page "/"
@inject DeveloperService developerService
<PageTitle>The reverse job board for .NET developers</PageTitle>
<HeadContent>
	<meta name="description" content="DotnetDevs aims to give power back to developers when looking for employment. Instead of companies posting their jobs, developers post their profiles.">
</HeadContent>

<div class="relative z-10 flex flex-wrap justify-center items-center pt-12 md:pt-20 pb-8 md:pb-12 max-w-6xl mx-auto px-8">
	<div class="flex-1">
		<div class="lg:max-w-5xl mx-auto">
			<h1 class="mb-5 text-center text-black text-4xl leading-tight md:text-5xl md:leading-tight lg:text-7xl lg:leading-tight font-bold">
				The reverse job board for <br class="hidden sm:block" /><span class="text-indigo-600">.NET developers</span>
			</h1>
			<p class="mb-10 text-lg lg:text-2xl leading-loose lg:leading-loose text-center text-gray-700">
				DotnetDevs empowers .NET developers available for their next job. No more scouring job boards and Linkedin recruiter spam. Sit back as companies reach out to you.
			</p>
			<a href="/choose-profile" class="bg-indigo-600 hover:bg-indigo-700 text-white mb-9 relative flex items-center justify-center w-fit max-w-xs md:max-w-xs px-8 md:px-12 py-3 md:py-4 mx-auto uppercase text-base lg:text-xl leading-loose lg:leading-loose font-semibold tracking-[1px]">
				Get started
			</a>
		</div>
	</div>
</div>
<div class="">
	<div class="relative flex flex-wrap justify-center items-center py-8 md:py-12 max-w-6xl mx-auto sm:px-8">
		<div class="flex-1">
			<div class="">
				<h2 class="mb-6 text-lg lg:text-2xl leading-loose lg:leading-loose text-left text-black font-semibold px-6 sm:px-0">
					Developers available now
				</h2>
			</div>
			<div class="flex flex-col space-y-8">
				@if (_developers == null)
				{
					<p><em>Loading...</em></p>
				}
				else
				{
					<DevTeaser Developers="@_developers" />
				}
			</div>
		</div>
	</div>
</div>


@code {
	private List<Developer> _developers;

	protected override async Task OnInitializedAsync()
	{
		_developers = await developerService.GetAll();
	}
}